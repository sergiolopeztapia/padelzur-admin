meta {
  name: READ clubes
  type: http
  seq: 2
}

get {
  url: https://cofwxkqqkkfzrlnggqmk.supabase.co/rest/v1/clubes?select=*
  body: none
  auth: inherit
}

params:query {
  select: *
  ~ciudad: eq.Algeciras
  ~id: eq.1
}

headers {
  apikey: {{apikey}}
}

settings {
  encodeUrl: false
  timeout: 0
}
